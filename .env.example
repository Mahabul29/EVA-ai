# EvaAI Chat - Environment Variables (Gemini API)
# Copy this file to .env and fill in your values

# Flask Secret Key (change in production)
SECRET_KEY=your-super-secret-key-here

# CORS Origins (set to your frontend domain in production)
CORS_ORIGINS=*

# Google Gemini API Configuration
# Get your FREE API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini Model Options (Free Tier - 1500 requests/day):
# gemini-2.5-flash        (default, fast & capable)
# gemini-2.5-flash-lite   (cheapest, fastest)
# gemini-3.1-flash-lite   (latest budget model)
# gemini-3-flash          (preview, good balance)
GEMINI_MODEL=gemini-2.5-flash

# App Settings
MAX_HISTORY=20
DEBUG=False
PORT=8000
